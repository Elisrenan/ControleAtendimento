[flake8]
max-line-length = 88
extend-ignore =
    # E203: whitespace before ':' — conflito com black
    E203,
    # W503: line break before binary operator — conflito com black
    W503
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    controle_atendimentos.db
per-file-ignores =
    # tests podem usar asserts e variáveis sem uso
    tests/*: S101
